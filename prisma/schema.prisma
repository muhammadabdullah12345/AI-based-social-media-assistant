generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  password       String
  posts          Post[]
  documents      Document[]
  socialAccounts SocialAccount[]
  createdAt      DateTime        @default(now())
}

model Post {
  id       String  @id @default(cuid())
  title    String
  content  String
  image    String?
  platform String

  sourceType String // "manual" | "document"
  documentId String?

  // Publishing fields
  status         String    @default("draft") // "draft" | "published" | "scheduled" | "failed"
  scheduledAt    DateTime?
  publishedAt    DateTime?
  platformPostId String? // ID returned by Facebook/Instagram after publishing
  publishError   String? // Store error message if publish failed

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Document {
  id        String          @id @default(cuid())
  filename  String
  fileType  String
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks    DocumentChunk[]
  createdAt DateTime        @default(now())
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  embedding  Json
}

// Stores connected Facebook Pages and Instagram Accounts per user
model SocialAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform    String // "facebook" | "instagram"
  accountId   String // Facebook Page ID or Instagram Business Account ID
  accountName String // Display name
  accessToken String // Long-lived page access token
  tokenExpiry DateTime?
  pageId      String? // Facebook Page ID (needed for Instagram too)
  igAccountId String? // Instagram Business Account ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, accountId])
}

// Tracks scheduled posts for the cron job
model ScheduledPost {
  id              String   @id @default(cuid())
  postId          String   @unique
  userId          String
  platform        String
  scheduledAt     DateTime
  status          String   @default("pending") // "pending" | "processing" | "published" | "failed"
  socialAccountId String? // Which account to publish to
  createdAt       DateTime @default(now())
}
